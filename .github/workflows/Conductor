name: Deploy to GitHub Pages
on:
  push:
    branches: ["master"] # Use "main" if your branch is named that
permissions:
  contents: read
  pages: write
  id-token: write
jobs:
  build_and_deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 18
      - run: yarn install
      - run: yarn build # This creates the /dist folder
      - uses: actions/upload-pages-artifact@v3
        with:
          path: './dist' # This tells GitHub where index.html is
      - id: deployment
        uses: actions/deploy-pages@v4
